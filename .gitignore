# Ignore Python bytecode cache directories
__pycache__/

# Ignore Python generated bytecode or object files
*.py[co]

# Installed Python module files
*.egg-info

# Compiled binary files
*.exe
*.o
*.obj

# Ignore generated and saved figures
*.png
*.jpg
*.jpeg
*.pdf

# Generated NumPy .npy/.npz files
*.npy

# MacOS-generated files
**/.DS_Store

# Configured cache for JAX jitted functions
jax_cache/

# Default CMake build directory
build/
